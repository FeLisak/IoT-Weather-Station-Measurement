# Configuração de Banco de Dados
DB_PATH=dados.db
SCHEMA_PATH=schema.sql

# Configuração de Porta Serial (para serial_reader.py)
# Windows: PORTA_SERIAL=COM3  (ou COM4, COM11, etc. — veja no Gerenciador de Dispositivos)
# macOS:   PORTA_SERIAL=/dev/tty.usbmodem14101  (ou /dev/tty.usbserial-*)
# Linux:   PORTA_SERIAL=/dev/ttyUSB0
PORTA_SERIAL=COM3
BAUD_RATE=9600

# Configuração da API
URL_API=http://localhost:5000/leituras

# Configuração do Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Padrões de Dados
LIMITE_LEITURAS_DEFAULT=50
LEITURAS_POR_PAGINA=20
